{
  "name": "remotion-aem-showcase",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "remotion preview src/index.tsx",
    "render": "remotion render src/index.tsx",
    "render:all": "npm run render -- AEMSpotlight-16x9 out/spotlight_16x9.mp4 && npm run render -- AEMSpotlight-9x16 out/spotlight_9x16.mp4 && npm run render -- AEMSpotlight-1x1 out/spotlight_1x1.mp4",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build:wasm": "node scripts/build-spotlight-wasm.js",
    "upgrade": "remotion upgrade",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,json}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,json}'",
    "type-check": "tsc --noEmit",
    "validate": "npm run type-check && npm run lint && npm run test",
    "prepare": "husky || true",
    "test:smoke": "npx remotion still src/index.tsx AEMSpotlight-16x9 out/smoke_16x9.png && npx remotion still src/index.tsx AEMSpotlight-9x16 out/smoke_9x16.png && npx remotion still src/index.tsx AEMSpotlight-1x1 out/smoke_1x1.png",
    "deploy:aem": "npm run render -- AEMSpotlight-16x9 out/spotlight_prod.mp4 && node scripts/upload-to-aem.js out/spotlight_prod.mp4 $REMOTION_RENDER_DEST"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/google-fonts": "^4.0.0",
    "@remotion/lottie": "^4.0.435",
    "@types/jsonwebtoken": "^9.0.10",
    "jsonwebtoken": "^9.0.3",
    "lottie-react": "^2.4.1",
    "node-fetch": "^3.3.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remotion": "^4.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@testing-library/react": "^14.1.2",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.47",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.18.1",
    "@typescript-eslint/parser": "^6.18.1",
    "@vitest/coverage-v8": "^1.1.4",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.0.6",
    "jsdom": "^23.2.0",
    "prettier": "^3.2.2",
    "typescript": "^5.3.3",
    "vitest": "^1.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
