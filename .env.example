# AEM Configuration
# ------------------
# Base URL for AEM Cloud Service (author or publish tier)
AEM_BASE_URL=https://publish-p12345-e67890.adobeaemcloud.com

# Bearer token for AEM API authentication (static token)
# Use this for quick testing. For production, use IMS credentials below.
AEM_TOKEN=your-ims-bearer-token

# IMS Service Account Authentication (Recommended for Production)
# ----------------------------------------------------------------
# These credentials enable automatic token refresh.
# Obtain from Adobe Developer Console > Service Account (JWT) credentials
#
# AEM_IMS_CLIENT_ID=your-client-id
# AEM_IMS_CLIENT_SECRET=your-client-secret
# AEM_IMS_TECHNICAL_ACCOUNT_ID=your-technical-account-id@techacct.adobe.com
# AEM_IMS_ORG_ID=your-org-id@AdobeOrg
# AEM_IMS_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# AEM_IMS_ENDPOINT=https://ims-na1.adobelogin.com
# AEM_IMS_METASCOPES=https://ims-na1.adobelogin.com/s/ent_aem_cloud_api

# GraphQL endpoint path (default: /content/graphql/global/endpoint)
AEM_GRAPHQL_ENDPOINT=/content/graphql/global/endpoint

# Content Fragment path for spotlight data
AEM_CONTENT_FRAGMENT_PATH=/content/dam/your-project/spotlight

# Persisted query path (alternative to inline query)
# AEM_PERSISTED_QUERY=/your-project/spotlight-query

# Development Settings
# --------------------
# Set to "true" to use mock data instead of live AEM
USE_MOCK_AEM=true

# AEM Tier Selection
# ------------------
# Set to "true" if targeting the Publish tier (defaults to false for Author)
AEM_PUBLISH_TIER=false

# Strict Mode: throw on AEM errors instead of falling back to mock data
# Set to "true" in production so failures are visible rather than silent
AEM_STRICT_MODE=false

# Deployment Settings
# -------------------
# Destination path in AEM Assets for rendered video upload
REMOTION_RENDER_DEST=/content/dam/spotlight/videos/hero_spotlight.mp4

# Remotion Render Settings
# ------------------------
# Output codec (h264, h265, vp8, vp9, prores)
# REMOTION_CODEC=h264

# Output quality (0-100 for lossy codecs)
# REMOTION_QUALITY=80

# Concurrency for rendering
# REMOTION_CONCURRENCY=50%

# Telemetry & Monitoring
# ----------------------
# Enable telemetry collection
TELEMETRY_ENABLED=false

# Backend: console | webhook | adobe-analytics | custom
TELEMETRY_BACKEND=console

# Webhook URL for external metrics collection (backend=webhook)
# TELEMETRY_WEBHOOK_URL=https://your-metrics-endpoint.com/ingest

# Adobe Analytics Report Suite ID (backend=adobe-analytics)
# Uses the server-side Data Insertion API — no browser SDK required.
# ADOBE_ANALYTICS_RSID=your-report-suite-id

# Sampling rate (0-1, percentage of events to send)
TELEMETRY_SAMPLE_RATE=1

# Include stack traces in error events (disable for privacy)
TELEMETRY_INCLUDE_STACKS=true

# Caching Configuration
# ---------------------
# Enable/disable caching (default: true)
CACHE_ENABLED=true

# Maximum items in memory cache
CACHE_MEMORY_MAX_SIZE=100

# Disk cache directory (for persistent caching)
CACHE_DISK_DIR=.cache/remotion

# Cache TTL in milliseconds (default: 30 minutes)
CACHE_TTL_MS=1800000

# Persist cache to disk
CACHE_PERSIST_DISK=false
