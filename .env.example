# AEM Configuration
# ------------------
# Base URL for AEM Cloud Service (author or publish tier)
AEM_BASE_URL=https://publish-p12345-e67890.adobeaemcloud.com

# Bearer token for AEM API authentication (IMS Service Account token)
AEM_TOKEN=your-ims-bearer-token

# GraphQL endpoint path (default: /content/graphql/global/endpoint)
AEM_GRAPHQL_ENDPOINT=/content/graphql/global/endpoint

# Content Fragment path for spotlight data
AEM_CONTENT_FRAGMENT_PATH=/content/dam/your-project/spotlight

# Persisted query path (alternative to inline query)
# AEM_PERSISTED_QUERY=/your-project/spotlight-query

# Development Settings
# --------------------
# Set to "true" to use mock data instead of live AEM
USE_MOCK_AEM=true

# AEM Tier Selection
# ------------------
# Set to "true" if targeting the Publish tier (defaults to false for Author)
AEM_PUBLISH_TIER=false

# Deployment Settings
# -------------------
# Destination path in AEM Assets for rendered video upload
REMOTION_RENDER_DEST=/content/dam/spotlight/videos/hero_spotlight.mp4

# Remotion Render Settings
# ------------------------
# Output codec (h264, h265, vp8, vp9, prores)
# REMOTION_CODEC=h264

# Output quality (0-100 for lossy codecs)
# REMOTION_QUALITY=80

# Concurrency for rendering
# REMOTION_CONCURRENCY=50%

# Telemetry & Monitoring
# ----------------------
# Enable telemetry collection
TELEMETRY_ENABLED=false

# Backend: console | webhook | adobe-analytics | custom
TELEMETRY_BACKEND=console

# Webhook URL for external metrics collection
# TELEMETRY_WEBHOOK_URL=https://your-metrics-endpoint.com/ingest

# Adobe Analytics Report Suite ID
# ADOBE_ANALYTICS_RSID=your-report-suite-id

# Sampling rate (0-1, percentage of events to send)
TELEMETRY_SAMPLE_RATE=1

# Include stack traces in error events (disable for privacy)
TELEMETRY_INCLUDE_STACKS=true
